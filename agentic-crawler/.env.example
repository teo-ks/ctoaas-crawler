# --- Direct Anthropic (default) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- LiteLLM / OpenAI-compatible proxy ---
# Set LLM_BASE_URL to switch from Anthropic SDK to OpenAI-compatible client.
# When set, LLM_API_KEY is used instead of ANTHROPIC_API_KEY.
#
# Examples:
#   LiteLLM local:   LLM_BASE_URL=http://localhost:4000
#   OpenRouter:      LLM_BASE_URL=https://openrouter.ai/api/v1
#
# LLM_BASE_URL=http://localhost:4000
# LLM_API_KEY=your_litellm_api_key_here

# Model to use for extraction (primary)
# Direct Anthropic:  claude-haiku-4-5-20251001
# Via LiteLLM:       anthropic/claude-haiku-4-5-20251001  (or whatever LiteLLM alias)
LLM_MODEL=bedrock-claude-haiku-3

# Fallback model used when primary fails
LLM_FALLBACK_MODEL=google-gemini-3-flash

# Proxy (optional — uncomment if Cloudflare blocks you)
# APIFY_PROXY_PASSWORD=your_apify_proxy_password
