# Anthropic direct (default when LLM_BASE_URL is not set)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible endpoint (LiteLLM, OpenRouter, etc.)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-key-here

# Model selection
LLM_MODEL=google/gemini-3-flash-preview
LLM_FALLBACK_MODEL=anthropic/claude-haiku-4.5

# Optional: proxy URL for Cloudflare-protected sites (any HTTP/HTTPS proxy)
# PROXY_URL=http://user:password@proxy.example.com:8080
